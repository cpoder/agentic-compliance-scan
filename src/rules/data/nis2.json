  "rules": [
    {
      "id": "nis2.risk-management.in-scope-no-risk-management",
      "category": "nis2-risk-management",
      "scope": "deployment",
      "jurisdictions": ["FR", "IT", "PT", "BE", "DE"],
      "title": "Agent acts on an in-scope system with no risk-management measures declared",
      "guidance": "Declare cybersecurity risk-management measures covering the agent's actions on the in-scope system.",
      "severity": "high",
      "appliesWhen": {
        "all": [{ "deploymentTouchesInScopeSystem": true }, { "controlAbsent": "riskManagement" }]
      },
      "references": [
        {
          "instrument": "nis2",
          "jurisdiction": "IT",
          "article": "Art. 24",
          "nationalRef": "Decreto Legislativo 138/2024",
          "source": "Reglyze nis2-mappings/countries/it.yaml (directive_article 21)",
          "validated": true
        },
        {
          "instrument": "nis2",
          "jurisdiction": "BE",
          "article": "Art. 30",
          "nationalRef": "Loi du 26 avril 2024 (NIS2)",
          "source": "Reglyze nis2-mappings/countries/be.yaml (directive_article 21)",
          "validated": true
        },
        {
          "instrument": "nis2",
          "jurisdiction": "DE",
          "article": "§ 30 Abs. 1 BSIG",
          "nationalRef": "BSIG (NIS2UmsuCG 2025)",
          "source": "Reglyze nis2-mappings/countries/de.yaml (directive_article 21)",
          "validated": true
        },
        {
          "instrument": "nis2",
          "jurisdiction": "PT",
          "article": "Art. 26.º e 27.º RJC",
          "nationalRef": "Decreto-Lei 125/2025 (Regime Jurídico da Cibersegurança)",
          "source": "Reglyze nis2-mappings/countries/pt.yaml (directive_article 21)",
          "validated": true
        },
        {
          "instrument": "nis2",
          "jurisdiction": "FR",
          "article": "Art. 14 (Titre II)",
          "nationalRef": "Projet de loi Résilience (Titre II), non promulgué",
          "source": "Reglyze nis2-mappings/countries/fr.yaml (directive_article 21)",
          "status": "draft",
          "validated": true
        }
      ]
    },
